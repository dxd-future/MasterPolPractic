<Window x:Class="MasterPol.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="550" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Icon="/Resources/app.ico">
    <Grid Background="{StaticResource PrimaryBackground}" Margin="0,0,0,-150">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource SecondaryBackground}" Padding="20">
            <Image Source="/Resources/logo.png" Height="80" Stretch="Uniform"/>
        </Border>
        <StackPanel Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="300" Margin="0,44,0,0">
            <TextBlock Text="МастерПол" FontFamily="Segoe UI" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="{StaticResource AccentColor}"
                       Margin="0,0,0,10"/>
            <TextBlock Text="Авторизация" FontFamily="Segoe UI" FontSize="24" FontWeight="Bold"
                       Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="{StaticResource AccentColor}"/>
            <Label Content="Логин" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUsername" Margin="0,0,0,15" Height="35"/>
            <Label Content="Пароль" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Margin="0,0,0,25" Height="35"/>
            <Button x:Name="btnLogin" Content="Войти" Click="BtnLogin_Click" Height="40" Width="150"/>
            <TextBlock x:Name="lblError" Foreground="Red" Margin="0,10,0,0" TextAlignment="Center" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>