<Page x:Class="MasterPol.Views.ProductionWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Производственные заказы" Background="{StaticResource PrimaryBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Производственные заказы" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgProduction" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="{StaticResource SecondaryBackground}"
                  CanUserSortColumns="True" RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
                <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Click="BtnRefresh_Click"/>
        </StackPanel>
    </Grid>
</Page>