<Page x:Class="MasterPol.Views.MaterialsWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Типы материалов" Background="{StaticResource PrimaryBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Справочник типов материалов" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgMaterials" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="{StaticResource SecondaryBackground}"
                  CanUserSortColumns="True" RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование материала" Binding="{Binding MaterialName}" Width="*"/>
                <DataGridTextColumn Header="Процент брака" Binding="{Binding DefectRate, StringFormat='{}{0}%'}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnAdd" Content="➕ Добавить" Click="BtnAdd_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnEdit" Content="✏️ Редактировать" Click="BtnEdit_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Click="BtnRefresh_Click"/>
        </StackPanel>
    </Grid>
</Page>