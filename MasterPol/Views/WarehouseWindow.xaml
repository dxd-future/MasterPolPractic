<Page x:Class="MasterPol.Views.WarehouseWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Складские остатки" Background="{StaticResource PrimaryBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Остатки продукции на складе" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgWarehouse" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="{StaticResource SecondaryBackground}"
                  CanUserSortColumns="True" RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="120"/>
                <DataGridTextColumn Header="Последнее обновление" Binding="{Binding LastUpdated, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Click="BtnRefresh_Click"/>
        </StackPanel>
    </Grid>
</Page>