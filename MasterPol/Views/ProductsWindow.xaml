<Page x:Class="MasterPol.Views.ProductsWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Продукция" Background="{StaticResource PrimaryBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Справочник продукции" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgProducts" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="{StaticResource SecondaryBackground}"
                  CanUserSortColumns="True" RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="100"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Тип продукции" Binding="{Binding ProductTypeName}" Width="150"/>
                <DataGridTextColumn Header="Тип материала" Binding="{Binding MaterialTypeName}" Width="150"/>
                <DataGridTextColumn Header="Мин. стоимость для партнёра" Binding="{Binding MinCostForPartner, StringFormat='N2'}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnAdd" Content="➕ Добавить" Click="BtnAdd_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnEdit" Content="✏️ Редактировать" Click="BtnEdit_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Click="BtnRefresh_Click"/>
        </StackPanel>
    </Grid>
</Page>