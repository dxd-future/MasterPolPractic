<Window x:Class="MasterPol.Views.SalesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Расширенная история продаж" Height="550" Width="750"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Icon="/Resources/app.ico">
    <Grid Background="{StaticResource PrimaryBackground}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="tbPartnerName" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="{StaticResource SecondaryBackground}" Padding="10" CornerRadius="8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Дата с:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="dpStartDate" Grid.Column="1" Margin="5" SelectedDateChanged="DateFilter_Changed"/>

                <TextBlock Grid.Column="2" Text="по:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <DatePicker x:Name="dpEndDate" Grid.Column="3" Margin="5" SelectedDateChanged="DateFilter_Changed"/>

                <TextBlock Grid.Column="4" Text="Тип:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <ComboBox x:Name="cbType" Grid.Column="5" Width="150" Margin="5" SelectionChanged="CbType_SelectionChanged" DisplayMemberPath="TypeName" SelectedValuePath="Id"/>

                <Button x:Name="btnClearDates" Grid.Column="6" Content="Сбросить даты" 
                        Click="BtnClearDates_Click" Width="100" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <DataGrid x:Name="dgSales" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="{StaticResource SecondaryBackground}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Дата продажи" Binding="{Binding SaleDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="#E8F0FE" Padding="10" Margin="0,10,0,0" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Итого продаж:" FontWeight="Bold" FontSize="14"/>
                <TextBlock x:Name="tbTotalQuantity" Grid.Column="1" Text="0" FontWeight="Bold" FontSize="14" 
                           Foreground="{StaticResource AccentColor}" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Button x:Name="btnClose" Grid.Row="4" Content="Закрыть" Click="BtnClose_Click" 
                Width="100" HorizontalAlignment="Right" Margin="0,15,0,0"/>
    </Grid>
</Window>