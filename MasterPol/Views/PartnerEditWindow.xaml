<Window x:Class="MasterPol.Views.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование партнёра" Height="650" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Icon="/Resources/app.ico">
    <Grid Background="{StaticResource PrimaryBackground}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Content="Тип партнёра:" Grid.Row="0" Grid.Column="0" Margin="5"/>
                <ComboBox x:Name="cbPartnerType" Grid.Row="0" Grid.Column="1" Margin="5">
                    <ComboBoxItem Content="Розничный"/>
                    <ComboBoxItem Content="Оптовый"/>
                </ComboBox>

                <Label Content="Название компании:" Grid.Row="1" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtName" Grid.Row="1" Grid.Column="1" Margin="5"/>

                <Label Content="Фамилия:" Grid.Row="2" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtLastName" Grid.Row="2" Grid.Column="1" Margin="5"/>

                <Label Content="Имя:" Grid.Row="3" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtFirstName" Grid.Row="3" Grid.Column="1" Margin="5"/>

                <Label Content="Отчество:" Grid.Row="4" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtMiddleName" Grid.Row="4" Grid.Column="1" Margin="5"/>

                <Label Content="Email:" Grid.Row="5" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtEmail" Grid.Row="5" Grid.Column="1" Margin="5"/>

                <Label Content="Код страны:" Grid.Row="6" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtPhoneCountry" Grid.Row="6" Grid.Column="1" Margin="5"/>

                <Label Content="Код города:" Grid.Row="7" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtPhoneCity" Grid.Row="7" Grid.Column="1" Margin="5"/>

                <Label Content="Номер телефона:" Grid.Row="8" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtPhoneNumber" Grid.Row="8" Grid.Column="1" Margin="5"/>

                <Label Content="Индекс:" Grid.Row="9" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtPostalCode" Grid.Row="9" Grid.Column="1" Margin="5"/>

                <Label Content="Область/край:" Grid.Row="10" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtRegion" Grid.Row="10" Grid.Column="1" Margin="5"/>

                <Label Content="Город:" Grid.Row="11" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtCity" Grid.Row="11" Grid.Column="1" Margin="5"/>

                <Label Content="Улица:" Grid.Row="12" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtStreet" Grid.Row="12" Grid.Column="1" Margin="5"/>

                <Label Content="Дом/строение:" Grid.Row="13" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtBuilding" Grid.Row="13" Grid.Column="1" Margin="5"/>

                <Label Content="ИНН:" Grid.Row="14" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtInn" Grid.Row="14" Grid.Column="1" Margin="5"/>

                <Label Content="Рейтинг:" Grid.Row="15" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtRating" Grid.Row="15" Grid.Column="1" Margin="5"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button x:Name="btnSave" Content="Сохранить" Click="BtnSave_Click" Width="100" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="Отмена" Click="BtnCancel_Click" Width="100" Background="#CCCCCC" Foreground="Black"/>
        </StackPanel>
    </Grid>
</Window>