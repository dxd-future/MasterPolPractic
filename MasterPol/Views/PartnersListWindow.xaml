<Page x:Class="MasterPol.Views.PartnersListWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Список партнёров" Background="{StaticResource PrimaryBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Партнёры" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="{StaticResource SecondaryBackground}" Padding="10" CornerRadius="8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Тип:" VerticalAlignment="Center" Margin="5,0,10,0"/>
                <ComboBox x:Name="cbFilterType" Grid.Column="1" Width="150" Margin="5">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="Розничный"/>
                    <ComboBoxItem Content="Оптовый"/>
                </ComboBox>

                <TextBlock Grid.Column="2" Text="Поиск:" VerticalAlignment="Center" Margin="15,0,10,0"/>
                <TextBox x:Name="txtSearch" Grid.Column="3" Margin="5" Height="30" 
                         TextChanged="TxtSearch_TextChanged"/>
                <Button x:Name="btnClearFilter" Grid.Column="4" Content="Сбросить" 
                        Click="BtnClearFilter_Click" Width="80" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <DataGrid x:Name="dgPartners" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow" CanUserSortColumns="True"
                  RowHeaderWidth="0" AlternatingRowBackground="{StaticResource SecondaryBackground}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тип" Binding="{Binding PartnerType}" Width="100"/>
                <DataGridTextColumn Header="Компания" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="ФИО директора" Width="200">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0} {1} {2}">
                            <Binding Path="LastName"/>
                            <Binding Path="FirstName"/>
                            <Binding Path="MiddleName"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="120"/>
                <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
            <Button x:Name="btnAdd" Content="➕ Добавить" Click="BtnAdd_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnEdit" Content="✏️ Редактировать" Click="BtnEdit_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnHistory" Content="📊 История продаж" Click="BtnHistory_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Click="BtnRefresh_Click"/>
        </StackPanel>
    </Grid>
</Page>