<Window x:Class="MasterPol.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мастер Пол - Система управления" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Icon="/Resources/app.ico">
    <Grid Background="{StaticResource PrimaryBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SecondaryBackground}" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="/Resources/logo.png" Height="50" Stretch="Uniform" Margin="0,0,15,0"/>
                    <TextBlock Text="Мастер Пол" FontSize="22" FontWeight="Bold" 
                               Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="Система управления партнёрами и производством" 
                           FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="#555555"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="tbUserInfo" FontSize="14" Foreground="#333333" 
                               VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="Выйти" Click="BtnLogout_Click" 
                            Width="80" Height="30" Background="#E74C3C" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="#EEEEEE" Height="40">
            <Button x:Name="btnPartners" Content="Партнёры" Click="BtnPartners_Click" 
                    Style="{StaticResource MenuButtonStyle}" Margin="5,0"/>
            <Button x:Name="btnProducts" Content="Продукция" Click="BtnProducts_Click" 
                    Style="{StaticResource MenuButtonStyle}" Margin="5,0"/>
            <Button x:Name="btnMaterials" Content="Материалы" Click="BtnMaterials_Click" 
                    Style="{StaticResource MenuButtonStyle}" Margin="5,0"/>
            <Button x:Name="btnEmployees" Content="Сотрудники" Click="BtnEmployees_Click" 
                    Style="{StaticResource MenuButtonStyle}" Margin="5,0"/>
            <Button x:Name="btnWarehouse" Content="Склад" Click="BtnWarehouse_Click" 
                    Style="{StaticResource MenuButtonStyle}" Margin="5,0"/>
            <Button x:Name="btnProduction" Content="Производство" Click="BtnProduction_Click" 
                    Style="{StaticResource MenuButtonStyle}" Margin="5,0"/>
        </StackPanel>

        <Frame x:Name="ContentFrame" Grid.Row="2" NavigationUIVisibility="Hidden" Margin="10"/>
    </Grid>
</Window>